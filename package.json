{
  "name": "unct",
  "version": "0.1.0",
  "private": true,
  "description": "Universal Network Config Toolkit — core/ stays Zero-Build (ADR-005); ui/ + final assembly use a scoped esbuild Build Step (ADR-014).",
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build": "node scripts/build.js",
    "pretest:e2e": "npm run build",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.0.1",
    "@vitest/coverage-v8": "^2.1.9",
    "esbuild": "^0.25.0",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "dompurify": "3.4.11",
    "fflate": "0.8.3",
    "js-yaml": "^4.2.0",
    "preact": "^10.24.0",
    "uqr": "0.1.3"
  }
}
